# ── LLM / embeddings ────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Claude Agent SDK (enrichment = Sonnet, classification = Opus).
# AUTH — the Agent SDK runs on the Claude Code CLI and can use EITHER:
#   (a) your Claude Code subscription login (run `claude login` once) -> leave the key BLANK, or
#   (b) a pay-as-you-go Anthropic API key below.
# Local dev off your login needs no key. Inside Docker the CLI login isn't present,
# so there you must set a key (or mount your ~/.claude credentials into the container).
ANTHROPIC_API_KEY=
CLAUDE_ENRICHMENT_MODEL=claude-sonnet-5
CLAUDE_THREAT_MODEL=claude-opus-4-8

# ── Data stores ─────────────────────────────────────────────────────
# For local dev use http://localhost:9200; docker-compose overrides to the service name.
ELASTICSEARCH_URL=http://localhost:9200
CHROMA_PERSIST_DIR=./data/chroma

# ── Reserved for future CTI connector (unused in this build) ─────────
ZEROFOX_TOKEN=
