# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/

# Node / frontend
node_modules/
frontend/dist/
*.local
# Generated by `tsc -b` (frontend composite build)
frontend/vite.config.js
frontend/vite.config.d.ts
*.tsbuildinfo

# Env & secrets
.env
.env.*
!.env.example

# Data stores (runtime-generated; seed scripts recreate)
backend/data/chroma/
backend/data/images/
backend/data/metrics.db
*.log

# ── PII protection ──────────────────────────────────────────────────
# Real personal profiles + generated corpus may contain private data
# (emails, phone, home address). Keep them local; never commit.
backend/data/profiles/*.private.json
backend/data/corpus/
!backend/data/corpus/.gitkeep

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
